# Port the server listens on (Railway sets this automatically — leave unset in production)
PORT=3001

# Comma-separated list of origins allowed to call this API (your deployed frontend URL)
FRONTEND_URL=https://emileeredpath.github.io

# Shared secret required (as "Authorization: Bearer <API_KEY>") on every request to
# /api/actions and /api/tasks. Generate a long random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set this in Railway's environment variables — never commit the real value.
API_KEY=replace-with-a-long-random-value

# Where the SQLite database file lives. On Railway, mount a Volume and point
# this at a path inside it (e.g. /data/ai-office.db) so data survives
# redeploys — without a volume, the filesystem is wiped on every deploy.
DATABASE_PATH=./data/ai-office.db
