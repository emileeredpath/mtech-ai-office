{
  "name": "ai-office-backend",
  "version": "0.2.0",
  "description": "AI Office backend API",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "node --loader ts-node/esm --no-warnings=ExperimentalWarning src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "node --loader ts-node/esm --no-warnings=ExperimentalWarning src/db/migrate.ts",
    "seed": "node --loader ts-node/esm --no-warnings=ExperimentalWarning src/db/seed.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "pg-format": "^1.0.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "anthropic": "^0.28.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.11.2",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2"
  }
}
